{
  "name": "paintbrush-takeoff",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "node server/index.js",
    "dev:electron": "wait-on tcp:5173 && electron .",
    "dev:desktop": "concurrently -k \"npm:dev:client\" \"npm:dev:electron\"",
    "build": "tsc --noEmit && vite build",
    "build:desktop": "npm run build",
    "desktop": "npm run build:desktop && electron .",
    "preview": "vite preview",
    "start": "node server/index.js",
    "invoice:review": "node scripts/review-invoices.mjs",
    "bot:telegram": "node server/telegramEstimatorBot.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "fabric": "^5.3.0",
    "idb-keyval": "^6.2.2",
    "jszip": "^3.10.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "telegraf": "^4.16.3",
    "tesseract.js": "^7.0.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/fabric": "^5.3.9",
    "@types/jszip": "^3.4.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^41.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^9.0.4"
  }
}
