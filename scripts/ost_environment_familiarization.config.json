{
  "enabled": true,
  "window_title_contains": "On-Screen Takeoff",
  "monitor_index": 1,
  "click_delay_ms": 450,
  "typing_interval_ms": 10,
  "use_ui_atlas": false,
  "adaptive_retries": {
    "enabled": true,
    "click_anchor_retries": 1
  },
  "maverick_logging": {
    "enabled": true,
    "runtime_config_path": "scripts/maverick_runtime.config.json",
    "project_id": "TP-0001"
  },
  "anchors": {
    "conditions_first_row": {
      "x": 2035,
      "y": 424
    },
    "conditions_second_row": {
      "x": 2109,
      "y": 596
    },
    "area_dropdown": {
      "x": 189,
      "y": 443
    },
    "page_next_button": {
      "x": 2176,
      "y": 276
    }
  },
  "steps": [
    {
      "type": "screenshot",
      "tag": "start",
      "label": "Capture start state"
    },
    {
      "type": "click_anchor",
      "anchor": "conditions_first_row",
      "label": "Select first condition row"
    },
    {
      "type": "sleep_ms",
      "ms": 600,
      "label": "Let condition highlight update"
    },
    {
      "type": "click_anchor",
      "anchor": "conditions_second_row",
      "label": "Switch to second condition row"
    },
    {
      "type": "sleep_ms",
      "ms": 600,
      "label": "Observe condition switch"
    },
    {
      "type": "click_anchor",
      "anchor": "area_dropdown",
      "label": "Open area dropdown"
    },
    {
      "type": "press",
      "key": "down",
      "label": "Move to next area option"
    },
    {
      "type": "press",
      "key": "enter",
      "label": "Apply selected area option"
    },
    {
      "type": "sleep_ms",
      "ms": 1000,
      "label": "Wait for area-linked highlights"
    },
    {
      "type": "screenshot",
      "tag": "after_area_switch",
      "label": "Capture after area switch"
    },
    {
      "type": "click_anchor",
      "anchor": "page_next_button",
      "label": "Navigate to next page 1"
    },
    {
      "type": "sleep_ms",
      "ms": 1100,
      "label": "Wait for page render 1"
    },
    {
      "type": "click_anchor",
      "anchor": "conditions_first_row",
      "label": "Re-select first condition"
    },
    {
      "type": "sleep_ms",
      "ms": 650,
      "label": "Observe condition on page 2"
    },
    {
      "type": "click_anchor",
      "anchor": "page_next_button",
      "label": "Navigate to next page 2"
    },
    {
      "type": "sleep_ms",
      "ms": 1100,
      "label": "Wait for page render 2"
    },
    {
      "type": "click_anchor",
      "anchor": "conditions_second_row",
      "label": "Re-select second condition"
    },
    {
      "type": "sleep_ms",
      "ms": 650,
      "label": "Observe condition on page 3"
    },
    {
      "type": "click_anchor",
      "anchor": "page_next_button",
      "label": "Navigate to next page 3"
    },
    {
      "type": "sleep_ms",
      "ms": 1200,
      "label": "Wait for page render 3"
    },
    {
      "type": "screenshot",
      "tag": "end",
      "label": "Capture final state"
    }
  ]
}
