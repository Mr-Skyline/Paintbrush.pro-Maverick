PORT=3000
# ElevenLabs streaming TTS (voice output)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# xAI Grok — voice agent (/api/agent/step + tools) and simple chat (/api/chat). Also accepts XAI_API_KEY.
GROK_API_KEY=
# Optional override (default grok-2-latest)
GROK_MODEL=grok-2-latest

# Telegram estimate assistant
TELEGRAM_BOT_TOKEN=
PAINT_COVERAGE_SQFT_PER_GALLON=350
DEFAULT_PAINT_COATS=2
